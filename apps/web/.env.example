# Database (PostgreSQL via Supabase or Railway)
DATABASE_URL="postgresql://user:password@host:port/database"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Anthropic (Claude AI) - for AI chat agent
ANTHROPIC_API_KEY=sk-ant-api03-...

# Resend (Email) - optional, emails are skipped if not set
RESEND_API_KEY=re_...
EMAIL_FROM="FreshSheet <noreply@freshsheet.app>"

# Supabase (Realtime) - optional, realtime updates disabled if not set
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Inngest (Background Jobs) - optional, background jobs disabled if not set
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=signkey-...

# POS Integrations (optional - enable OAuth for specific providers)
# SQUARE_CLIENT_ID=sq0idp-...
# SQUARE_CLIENT_SECRET=sq0csp-...
# SQUARE_WEBHOOK_SIGNATURE_KEY=...
# TOAST_CLIENT_ID=...
# TOAST_CLIENT_SECRET=...
# TOAST_API_HOSTNAME=https://ws-api.toasttab.com
# CLOVER_CLIENT_ID=...
# CLOVER_CLIENT_SECRET=...
# LIGHTSPEED_CLIENT_ID=...
# LIGHTSPEED_CLIENT_SECRET=...
# SPOTON_CLIENT_ID=...
# SPOTON_CLIENT_SECRET=...

# Stripe (Billing) - optional, billing features disabled if not set
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Accounting Integration (QuickBooks)
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
# Accounting Integration (Xero)
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
